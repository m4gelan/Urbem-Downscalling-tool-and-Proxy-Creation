    "18": 6,  "19": 6,  "20": 6,  "21": 6,  "22": 6,
    "23": 7,  "24": 7,  "25": 7,  "26": 7,  "27": 7,  "28": 7,  "29": 7,
    "30": 8,  "31": 8,  "32": 8,  "33": 8,
    "34": 9,
    "35": 10, "36": 10, "40": 10, "41": 10,
    "37": 11, "38": 11, "39": 11,
    "42": 12, "43": 12, "44": 12,
    "7":  13, "8":  13, "9":  13
